# Copy to ".env": cp .env.example .env (or rely on run_local.py to copy once)

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG DB: persist = embedded sqlite under local_data/chroma (default, no separate server).
# Set CHROMA_MODE=http plus host/port only if you run a standalone Chroma server.
CHROMA_MODE=persist
CHROMA_PERSIST_DIR=
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8002
CHROMA_COLLECTION=finance_knowledge

# true = no Redis installation required (memory lives in-process for this demo).
# Set false + REDIS_URL to use a real Redis instance.
REDIS_USE_FAKEREDIS=true
REDIS_URL=redis://127.0.0.1:6379

BANKING_API_URL=http://127.0.0.1:8001
AGENT_API_URL=http://127.0.0.1:8000

# Optional manual n8n (npm install -g n8n); irrelevant if you skip n8n.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_plaintext

DEFAULT_USER_ID=user_001
LOG_LEVEL=INFO
